# Gemini AI Configuration
VITE_GOOGLE_API_KEY=your_google_api_key_here
VITE_AI_AUTOMATION_MODEL=gemini-2.0-flash

# Firebase Configuration (for push notifications)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API Configuration
VITE_API_BASE_URL=https://api.example.com
# Optional: force ngrok interstitial bypass header even when URL is not *.ngrok-free.dev
VITE_ENABLE_NGROK_BYPASS=false
VITE_WS_BASE_URL=wss://staging-websockets.habeep.org/backend/api/v2

# App Configuration
VITE_APP_NAME=Habeep Admin Dashboard
VITE_APP_VERSION=2.0.0
VITE_APP_DESCRIPTION=Comprehensive admin dashboard for Habeep real estate platform
